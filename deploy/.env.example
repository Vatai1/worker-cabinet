# === Registry ===
REGISTRY=vatai12
FRONTEND_IMAGE=worker-cabinet-frontend:latest
BACKEND_IMAGE=worker-cabinet-backend:latest
NOTIFICATION_IMAGE=worker-cabinet-notification:latest

# === Database (postgres) ===
DB_HOST=postgres
DB_PORT=5432
DB_NAME=worker_cabinet
DB_USER=postgres
DB_PASSWORD=PLACEHOLDER_PASSWORD

# === JWT ===
JWT_SECRET=PLACEHOLDER_JWT_SECRET

# === S3 (MinIO) ===
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=PLACEHOLDER_S3_KEY
S3_BUCKET=worker-cabinet

# === MinIO ===
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BROWSER=off

# === RabbitMQ ===
RABBITMQ_DEFAULT_USER=worker_cabinet
RABBITMQ_PASSWORD=PLACEHOLDER_RABBIT_PASS
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672

# === Mail (notification-service) ===
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM="Worker Cabinet" <noreply@example.com>
NOTIFICATION_SECRET=changeme

# === OnlyOffice ===
ONLYOFFICE_JWT_ENABLED=true
ONLYOFFICE_JWT_SECRET=PLACEHOLDER_ONLYOFFICE_SECRET
ONLYOFFICE_JWT_HEADER=Authorization
ONLYOFFICE_JWT_BODY=false
ONLYOFFICE_WOPI_ENABLED=true
ONLYOFFICE_ALLOW_PRIVATE=true
ONLYOFFICE_ALLOW_META=true
ONLYOFFICE_UNAUTH_STORAGE=false
ONLYOFFICE_DB_TYPE=postgres
ONLYOFFICE_DB_HOST=postgres
ONLYOFFICE_DB_PORT=5432
ONLYOFFICE_DB_NAME=onlyoffice

# === Hermes Agent ===
HERMES_UID=1000
HERMES_GID=1000
HERMES_API_KEY=changeme
HERMES_PORT=8642

# === SearXNG ===
SEARXNG_PORT=8888

# === Ports (host mapping) ===
BACKEND_PORT=5000
BACKEND_INTERNAL_PORT=5000
NOTIFICATION_PORT=5001
NOTIFICATION_INTERNAL_PORT=5001
APP_PORT=80
