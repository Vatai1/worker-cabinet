# Адрес registry (опционально, если используется — включите в FRONTEND_IMAGE)
# REGISTRY=registry.example.com

# Полное имя образа фронтенда (registry + имя + тег)
# Важно: образ должен быть собран с --build-arg VITE_API_BASE_URL=/api
# Команда сборки: npm run docker:build:frontend
FRONTEND_IMAGE=vatai12/worker-cabinet-frontend:latest

APP_PORT=80
BACKEND_HOST=192.168.1.100
BACKEND_PORT=5000
NGINX_SERVER_NAME=_

# nginx envsubst: только указанные переменные, остальные ($host, $uri и т.д.) не трогать
# Используется синтаксис ${} в docker-compose.app.yml
NGINX_ENVSUBST_PARAMS=$BACKEND_HOST $BACKEND_PORT $NGINX_SERVER_NAME
