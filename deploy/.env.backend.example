REGISTRY=registry.example.com
BACKEND_IMAGE=worker-cabinet-backend:latest
NOTIFICATION_IMAGE=worker-cabinet-notification:latest

DB_NAME=worker_cabinet
DB_USER=postgres
DB_PASSWORD=PLACEHOLDER_PASSWORD
DB_PORT=5432
JWT_SECRET=PLACEHOLDER_JWT_SECRET

S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=PLACEHOLDER_S3_SECRET
S3_BUCKET=worker-cabinet
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

ONLYOFFICE_JWT_ENABLED=true
ONLYOFFICE_JWT_SECRET=PLACEHOLDER_OO_JWT_SECRET

RABBITMQ_PASSWORD=PLACEHOLDER_RMQ_PASSWORD
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672

BACKEND_PORT=5000
NOTIFICATION_PORT=5001

MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=
MAIL_PASSWORD=PLACEHOLDER_MAIL_PASSWORD
MAIL_FROM="Worker Cabinet" <noreply@example.com>
NOTIFICATION_SECRET=PLACEHOLDER_NOTIF_SECRET

HERMES_API_KEY=PLACEHOLDER_HERMES_KEY
HERMES_PORT=8642
SEARXNG_PORT=8888
