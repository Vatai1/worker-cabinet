{
  "name": "worker-cabinet-backend",
  "version": "1.0.0",
  "description": "Backend for Worker Cabinet",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "migrate": "node src/db/migrate.js",
    "seed": "node src/db/seed.js",
    "init:s3": "node src/db/init-s3-bucket.js",
    "init:templates": "node src/db/init-template-folder.js",
    "init:indexes": "node src/db/create-indexes.js",
    "test:syntax": "node src/tests/syntax-check.js",
    "test:all": "node --test --test-concurrency=1 src/tests/*.test.js",
    "test:auth": "node --test src/tests/auth.test.js",
    "test:vacation-history": "node --test src/tests/vacation-history.test.js",
    "test:departments": "node --test src/tests/departments.test.js",
    "test:notifications": "node --test src/tests/notifications.test.js",
    "test:users": "node --test src/tests/users.test.js",
    "test:vacation": "node --test src/tests/vacation.test.js",
    "test:surveys": "node --test src/tests/surveys.test.js",
    "test:timesheet": "node --test src/tests/timesheet.test.js",
    "test:projects": "node --test src/tests/projects.test.js",
    "test:onboarding": "node --test src/tests/onboarding.test.js",
    "test:dictionaries": "node --test src/tests/dictionaries.test.js",
    "test:hierarchy": "node --test src/tests/hierarchy.test.js",
    "test:documents": "node --test src/tests/documents.test.js",
    "test:user-documents": "node --test src/tests/user-documents.test.js",
    "test:calendar": "node --test src/tests/calendar.test.js",
    "test:admin": "node --test src/tests/admin.test.js",
    "test:auth-extended": "node --test src/tests/auth-extended.test.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.990.0",
    "@aws-sdk/s3-request-presigner": "^3.1016.0",
    "amqplib": "^1.0.7",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "docxtemplater": "^3.68.3",
    "dotenv": "^16.3.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.1",
    "express-validator": "^7.3.1",
    "httpntlm": "^1.8.13",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.2.1",
    "pdfkit": "^0.18.0",
    "pg": "^8.11.3",
    "pizzip": "^3.2.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
