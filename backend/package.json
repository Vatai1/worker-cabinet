{
  "name": "worker-cabinet-backend",
  "version": "1.0.0",
  "description": "Backend for Worker Cabinet",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "bot": "node src/telegram-bot.js",
    "migrate": "node src/db/migrate.js",
    "seed": "node src/db/seed.js",
    "init:s3": "node src/db/init-s3-bucket.js",
    "init:templates": "node src/db/init-template-folder.js",
    "init:indexes": "node src/db/create-indexes.js",
    "test:syntax": "node src/tests/syntax-check.js",
    "test:telegram": "node src/tests/telegram-syntax-check.js",
