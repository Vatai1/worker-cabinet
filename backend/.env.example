# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=worker_cabinet
DB_USER=postgres
DB_PASSWORD=postgres

# JWT (REQUIRED - no fallback)
JWT_SECRET=your-secret-key-change-this-in-production
JWT_EXPIRES_IN=7d

# S3/MinIO
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin123
S3_BUCKET=worker-cabinet

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_BOT_USERNAME=your_bot_username
TELEGRAM_ADMIN_CHAT_ID=admin_telegram_chat_id_here

# Outlook Online (Microsoft 365 / Graph API)
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=
OUTLOOK_REDIRECT_URI=http://localhost:3000/calendar/callback

# Exchange On-Premises (EWS)
EWS_URL=https://mail.company.com/EWS/Exchange.asmx
EWS_USERNAME=
EWS_PASSWORD=
EWS_DOMAIN=
