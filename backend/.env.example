# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=worker_cabinet
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false

# JWT (REQUIRED - no fallback)
JWT_SECRET=your-secret-key-change-this-in-production
JWT_EXPIRES_IN=7d

# S3/MinIO
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin123
S3_BUCKET=worker-cabinet

# Outlook Online (Microsoft 365 / Graph API)
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=
OUTLOOK_REDIRECT_URI=http://localhost:3000/calendar/callback

# RabbitMQ
RABBITMQ_URL=amqp://worker_cabinet:rabbitmq_secret@localhost:5672

# Keycloak (optional — leave empty to use basic JWT auth)
KEYCLOAK_URL=
KEYCLOAK_PUBLIC_URL=
KEYCLOAK_REALM=
KEYCLOAK_CLIENT_ID=
KEYCLOAK_CLIENT_SECRET=