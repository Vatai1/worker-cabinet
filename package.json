{
  "name": "worker-cabinet",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run dev:infra && npm run dev:setup && concurrently \"npm run dev:frontend\" \"npm run dev:backend\" \"npm run dev:notifications\" \"npm run dev:mini-agent\"",
    "dev:frontend": "vite",
    "dev:backend": "cd backend && npm run dev",
    "dev:notifications": "cd notification-service && npm run dev",
    "dev:mini-agent": "bash scripts/run-mini-agent.sh",
    "dev:infra": "docker compose --env-file backend/.env -f deploy/docker-compose.dev-no-kc.yml up -d",
    "dev:infra:down": "docker compose --env-file backend/.env -f deploy/docker-compose.dev-no-kc.yml down",
    "dev:infra:logs": "docker compose --env-file backend/.env -f deploy/docker-compose.dev-no-kc.yml logs -f",
    "dev:setup": "read -p 'Run database seed? (y/N) ' confirm && [ \"$confirm\" = 'y' ] && (cd backend && npm run seed && cd ../notification-service && npm run migrate) || echo 'Skipping seed'",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "install:all": "npm install && cd backend && npm install && cd ../notification-service && npm install",
    "backend:install": "cd backend && npm install",
    "backend:migrate": "cd backend && npm run migrate",
    "backend:seed": "cd backend && npm run seed",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "deploy:dev": "node ./deploy/deploy.js dev start",
    "deploy:dev:services": "node ./deploy/deploy.js dev services",
    "deploy:dev:stop": "node ./deploy/deploy.js dev stop",
    "deploy:dev:logs": "node ./deploy/deploy.js dev logs",
    "deploy:dev:status": "node ./deploy/deploy.js dev status",
    "deploy:prod": "node ./deploy/deploy.js prod deploy",
    "deploy:prod:build": "node ./deploy/deploy.js prod build",
    "deploy:prod:start": "node ./deploy/deploy.js prod start",
    "deploy:prod:stop": "node ./deploy/deploy.js prod stop",
    "deploy:prod:logs": "node ./deploy/deploy.js prod logs",
    "deploy:prod:status": "node ./deploy/deploy.js prod status",
    "deploy:single": "node ./deploy/deploy.js single deploy",
    "deploy:single:build": "node ./deploy/deploy.js single build",
    "deploy:single:start": "node ./deploy/deploy.js single start",
    "deploy:single:stop": "node ./deploy/deploy.js single stop",
    "deploy:single:restart": "node ./deploy/deploy.js single restart",
    "deploy:single:logs": "node ./deploy/deploy.js single logs",
    "deploy:single:status": "node ./deploy/deploy.js single status",
    "deploy:single:migrate": "node ./deploy/deploy.js single migrate",
    "docker:build:frontend": "docker build -f Dockerfile.frontend --build-arg VITE_API_BASE_URL=${VITE_API_BASE_URL:-/api} -t worker-cabinet-frontend:latest .",
    "docker:build:backend": "docker build -f Dockerfile.backend -t worker-cabinet-backend:latest .",
    "docker:build:notification": "docker build -t worker-cabinet-notification:latest ./notification-service",
    "docker:build": "npm run docker:build:frontend && npm run docker:build:backend && npm run docker:build:notification",
    "docker:push:frontend": "docker tag worker-cabinet-frontend:latest $REGISTRY/$FRONTEND_IMAGE:latest && docker push $REGISTRY/$FRONTEND_IMAGE:latest",
    "docker:push:backend": "docker tag worker-cabinet-backend:latest $REGISTRY/$BACKEND_IMAGE:latest && docker push $REGISTRY/$BACKEND_IMAGE:latest",
    "docker:push:notification": "docker tag worker-cabinet-notification:latest $REGISTRY/$NOTIFICATION_IMAGE:latest && docker push $REGISTRY/$NOTIFICATION_IMAGE:latest",
    "docker:push": "npm run docker:push:frontend && npm run docker:push:backend && npm run docker:push:notification"
  },
  "dependencies": {
    "@dicebear/collection": "^9.4.2",
    "@dicebear/core": "^9.4.2",
    "@xyflow/react": "^12.10.1",
    "clsx": "^2.0.0",
    "date-fns": "^4.1.0",
    "dompurify": "^3.4.11",
    "lucide-react": "^0.300.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-pdf": "^9.2.1",
    "react-router-dom": "^6.21.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.2.0",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^25.2.3",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "concurrently": "^9.2.1",
    "eslint": "^8.55.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.2.2",
    "vite": "^7.3.1"
  }
}
