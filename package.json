{
  "name": "worker-cabinet",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "start": "npm run db:up && npm run db:wait && npm run db:setup && concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev": "npm run db:setup && concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "vite",
    "dev:backend": "cd backend && npm run dev",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "install:all": "npm install && npm run backend:install",
    "backend:install": "cd backend && npm install",
    "backend:migrate": "cd backend && npm run migrate",
    "backend:seed": "cd backend && npm run seed",
    "db:up": "docker-compose up -d",
    "db:down": "docker-compose down",
    "db:wait": "node scripts/wait-for-db.js",
    "db:setup": "npm run backend:migrate && npm run backend:seed"
  },
  "dependencies": {
    "clsx": "^2.0.0",
    "date-fns": "^4.1.0",
    "dotenv": "^16.3.1",
    "lucide-react": "^0.300.0",
    "pg": "^8.20.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.21.0",
    "tailwind-merge": "^2.2.0",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "concurrently": "^9.2.1",
    "eslint": "^8.55.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.2.2",
    "vite": "^5.0.8"
  }
}
