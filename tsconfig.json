{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,

    /* Path aliases */
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": ["core/**/*.ts", "core/**/*.tsx", "modules/**/*.ts", "modules/**/*.tsx", "shared/**/*.ts", "shared/**/*.tsx", "*.ts", "*.tsx"],
  "exclude": ["vite.config.ts", "docker", "node_modules", "notification-service"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
