{
  "realm": "worker-cabinet",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "permanentLockout": false,
  "maxFailureWaitSeconds": 900,
  "minimumQuickLoginWaitSeconds": 60,
  "waitIncrementSeconds": 60,
  "quickLoginCheckMilliSeconds": 1000,
  "maxDeltaTimeSeconds": 43200,
  "failureFactor": 5,
  "roles": {
    "realm": [
      { "name": "admin", "description": "Администратор системы" },
      { "name": "hr", "description": "HR-менеджер" },
      { "name": "manager", "description": "Руководитель" },
      { "name": "employee", "description": "Сотрудник" },
      { "name": "onboarding", "description": "Онбординг-менеджер" }
    ],
    "client": {
      "realm-management": [],
      "worker-cabinet": []
    }
  },
  "defaultRole": {
    "name": "employee"
  },
  "clients": [
    {
      "clientId": "worker-cabinet",
      "name": "Worker Cabinet",
      "description": "Worker Cabinet HR System",
      "enabled": true,
      "publicClient": false,
      "secret": "worker-cabinet-secret",
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "authorizationServicesEnabled": false,
      "redirectUris": ["http://localhost:*", "http://localhost:3000/*", "http://localhost:3000/login", "http://localhost:80/*", "http://localhost:5000/*"],
      "adminUrl": "http://localhost:3000",
      "rootUrl": "http://localhost:3000",
      "baseUrl": "/",
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "oauth2.device.authorization.grant.enabled": "false"
      },
      "protocolMappers": [
        {
          "name": "realm roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "multivalued": "true",
            "realm.roles.in.id.token": "true",
            "realm.roles.in.access.token": "true",
            "access.token.claim": "true",
            "id.token.claim": "true",
            "claim.name": "realm_roles"
          }
        },
        {
          "name": "email",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "email",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "email",
            "jsonType.label": "String"
          }
        },
        {
          "name": "first name",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "firstName",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "given_name",
            "jsonType.label": "String"
          }
        },
        {
          "name": "last name",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "lastName",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "family_name",
            "jsonType.label": "String"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "admin@example.com",
      "email": "admin@example.com",
      "firstName": "Администратор",
      "lastName": "Системы",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "admin123",
          "temporary": false
        }
      ],
      "realmRoles": ["admin", "employee"],
      "attributes": {
        "position": ["System Administrator"]
      }
    },
    {
      "username": "ivanov@example.com",
      "email": "ivanov@example.com",
      "firstName": "Иван",
      "lastName": "Иванов",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "password123",
          "temporary": false
        }
      ],
      "realmRoles": ["employee"],
      "attributes": {
        "position": ["Разработчик"]
      }
    },
    {
      "username": "petrov@example.com",
      "email": "petrov@example.com",
      "firstName": "Пётр",
      "lastName": "Петров",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "password123",
          "temporary": false
        }
      ],
      "realmRoles": ["manager", "employee"],
      "attributes": {
        "position": ["Руководитель отдела"]
      }
    },
    {
      "username": "elena@example.com",
      "email": "elena@example.com",
      "firstName": "Елена",
      "lastName": "Сидорова",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "password123",
          "temporary": false
        }
      ],
      "realmRoles": ["hr", "employee"],
      "attributes": {
        "position": ["HR-менеджер"]
      }
    }
  ]
}
