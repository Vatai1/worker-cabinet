# Server
PORT=5001
NODE_ENV=development

# Database (shared with main backend)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=worker_cabinet
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false

# RabbitMQ
RABBITMQ_URL=amqp://worker_cabinet:rabbitmq_secret@localhost:5672

# Email (SMTP)
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM='"Worker Cabinet" <noreply@example.com>'

# Internal auth secret
NOTIFICATION_SECRET=change-this-secret-in-production
